{
  "name": "modern-space-war",
  "version": "0.1.1",
  "description": "A monochrome multiplayer Spacewar-inspired browser and desktop game.",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win portable",
    "dist:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.soopahfly.modernspacewar",
    "productName": "Modern Space War",
    "files": [
      "index.html",
      "styles.css",
      "game.js",
      "server.js",
      "package.json",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
